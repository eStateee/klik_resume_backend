# ==============================================================================
# Django
# ==============================================================================
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# ==============================================================================
# PostgreSQL
# ==============================================================================
POSTGRES_DB=klik_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
