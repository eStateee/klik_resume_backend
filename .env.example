REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ==============================================================================
# CRM (AlfaCRM)
# ==============================================================================
CRM_API_URL=https://demo.alfacrm.pro
CRM_EMAIL=your-crm-email@example.com
